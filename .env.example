# ----------------------------------------------------------------------------
# Hotel turnkey template — environment variables (EXAMPLE)
#
# Copy this file to ".env" and fill in your real values.
# IMPORTANT: use the Supabase *connection pooler* (port 6543), NOT the
# direct connection (5432). Serverless platforms (Vercel) cannot reach the
# direct 5432 endpoint; the pooler is required for deployments.
# ----------------------------------------------------------------------------

# Supabase Postgres — connection pooler (transaction mode)
# Format: postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL="postgresql://postgres.tllhcgdbyecsnvkapqqh:<DB_PASSWORD>@aws-0-ca-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Stripe (test mode)
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# Public site URL (used for Stripe redirect URLs). Set to your Vercel domain in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
